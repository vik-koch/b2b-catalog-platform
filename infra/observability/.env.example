# Template for the observability stack's .env (lives next to compose.yml on the
# VM). Only long-lived VMs (dev/prod) run this stack.

# Ops hostname for Grafana. Needs its own DNS record (A -> this VM, DNS-only)
# and a Let's Encrypt cert issues on first hit.
GRAFANA_DOMAIN=logs.example.com

# Grafana's built-in `admin` password. Keep stable across deploys.
GRAFANA_ADMIN_PASSWORD=change-me
