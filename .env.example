# Copy to .env and adjust values. Nx loads this file (with ${VAR} expansion)
# for all targets; Docker Compose reads it for compose.db.yml.

# --- API (NestJS) ---
API_HOST=localhost
API_PORT=3000

# Trusted proxy hops for rate limiting. 0 = trust none (correct for
# the nx-served dev/e2e API, which has no proxy in front). The deployed compose
# stack sits behind Traefik and sets 1 so the throttler keys on the real client.
# TRUST_PROXY_HOPS=0

# Base URL the Angular SSR process uses to reach the API server-side.
# The browser always uses the relative /api path (dev proxy / Traefik).
API_URL=http://${API_HOST}:${API_PORT}/api

# --- Web (Angular SSR) ---
# Hostname this deployment serves (SSR host allowlist; Traefik host rule in prod)
APP_DOMAIN=localhost
# Public origin the browser reaches this deployment on. Used by the SSR
# transfer cache to match server-side API fetches (via API_URL) with the
# browser's requests so hydration doesn't refetch. Dev server runs on 4200.
APP_ORIGIN=http://localhost:4200
# Production Node server port only; the dev server uses 4200
WEB_PORT=4000

# --- Per-deployment config ---
# The web (SSR) and API load their branding/text/wording whole from these files;
# there is no baked default, so an unset var or a missing file fails the boot.
# For nx serve these point at the committed demo config (paths relative to the
# workspace root). Docker uses the ./config mount instead (see compose.yml).
DEPLOYMENT_CONFIG_FILE=/config/deployment.4json
APP_TEXT_FILE=/config/app-text.json
INQUIRY_TEXT_FILE=/config/inquiry-text.json
CONFIG_ASSETS_DIR=/config/assets

# --- PostgreSQL (consumed by compose.db.yml to bootstrap the container) ---
POSTGRES_DB=b2b_catalog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Host/port the app connects to (host side of the container port mapping)
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Connection string used by the API and drizzle-kit
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${POSTGRES_DB}

# --- Mail ---
# Dev/demo use Mailpit (below, in compose.db.yml); prod uses a real provider.
# Only read in server mode (the migrate/seed one-shots don't send mail).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=Coffee Kontor <no-reply@coffee-kontor.example>
# Where the inquiry form is delivered.
MAIL_CONTACT_TO=hallo@coffee-kontor.example
# MAIL_USER / MAIL_PASSWORD: leave unset for Mailpit (no auth); set for a real
# provider. MAIL_SECURE=true for implicit TLS (port 465); unset for STARTTLS
# and for Mailpit.
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_SECURE=false
