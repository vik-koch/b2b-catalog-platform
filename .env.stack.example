# Template for a VPS stack's .env (lives next to compose.yml on the VM).

# Stack identifier — unique per stack on the VM (dev | prod).
# Used for the Traefik router names.
STACK_NAME=dev

# Public hostname of this stack — Traefik host rule + Let's Encrypt cert
APP_DOMAIN=b2b-dev.OWNER.com

# Images built by CI
API_IMAGE=ghcr.io/OWNER/b2b-catalog-platform-api:0.1.0
WEB_IMAGE=ghcr.io/OWNER/b2b-catalog-platform-web:0.1.0

# PostgreSQL — only reachable on the stack-internal Docker network
POSTGRES_DB=b2b_catalog
POSTGRES_USER=b2b_catalog
POSTGRES_PASSWORD=change-me
