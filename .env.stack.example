# Template for a VPS stack's .env (lives next to compose.yml on the VM).

# Stack identifier — unique per stack on the VM (dev | prod).
# Used for the Traefik router names.
STACK_NAME=dev

# Public hostname of this stack — Traefik host rule + Let's Encrypt cert
APP_DOMAIN=b2b-dev.OWNER.com

# Images built by CI
API_IMAGE=ghcr.io/vik-koch/b2b-catalog-platform-api:0.1.0
WEB_IMAGE=ghcr.io/vik-koch/b2b-catalog-platform-web:0.1.0

# PostgreSQL — only reachable on the stack-internal Docker network
POSTGRES_DB=b2b_catalog
POSTGRES_USER=b2b_catalog
POSTGRES_PASSWORD=change-me

# Mail (SMTP; see ADR 0013). Required by the api in server mode.
# - Non-prod (dev/demo): deploy with the compose.mailpit.yml overlay and point
#   these at its sink — MAIL_HOST=mailpit, MAIL_PORT=1025, no MAIL_USER/PASSWORD.
# - Prod: a real provider's host/port/credentials; MAIL_SECURE=true for
#   implicit TLS (port 465), MAIL_USER/MAIL_PASSWORD as the provider requires.
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=Coffee Kontor <no-reply@coffee-kontor.example>
MAIL_CONTACT_TO=hallo@coffee-kontor.example
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_SECURE=false

# Reviewer inbox basic-auth (only with the compose.mailpit.yml overlay). An
# htpasswd "user:hashed" entry; generate an SHA1 one (no '$' to trip Compose):
#   printf '%s' 'the-password' | openssl sha1 -binary | openssl base64
#   -> INBOX_BASICAUTH=reviewer:{SHA}<that output>
# INBOX_BASICAUTH=reviewer:{SHA}...
